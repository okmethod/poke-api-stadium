{
  "compilerOptions": {
    /* 基本設定 */
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext"],
    "types": ["@cloudflare/workers-types", "chai"],

    /* 厳格な型チェック */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "allowJs": true,
    "checkJs": true,

    /* パスエイリアス */
    "paths": {
      "@/*": ["./src/*"]
    },

    /* 役割の明確化 */
    "noEmit": true,  // コンパイルはWranglerに任せる
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*", "tests/**/*", "vitest.config.ts"],
  "exclude": ["node_modules", ".wrangler"]
}